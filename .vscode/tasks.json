{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Start Docker Container for Build",
            "type": "shell",
            "command": "docker run --rm -it -v ${workspaceFolder}/snapclient:${workspaceFolder}/snapclient -v ${workspaceFolder}/configs:${workspaceFolder}/snapclient/configs -w ${workspaceFolder}/snapclient -v /dev:/dev --privileged espressif/idf:v5.1.1",
            "problemMatcher": []
        },
        {
            "label": "Build, Flash and Monitor (Docker)",
            "type": "shell",
            "command": "docker run --rm -it -v ${workspaceFolder}/snapclient:${workspaceFolder}/snapclient -w ${workspaceFolder}/snapclient -v ${workspaceFolder}/configs:${workspaceFolder}/snapclient/configs -v /dev:/dev --privileged espressif/idf:v5.1.1 /bin/bash -c '. $IDF_PATH/export.sh && idf.py build flash monitor'",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": {
                "owner": "cpp",
                "fileLocation": ["relative", "${workspaceFolder}"],
                "pattern": {
                    "regexp": "^(.*):(\\d+):(\\d+):\\s+(warning|error):\\s+(.*)$",
                    "file": 1,
                    "line": 2,
                    "column": 3,
                    "severity": 4,
                    "message": 5
                }
            }
        },
        {
            "label": "Build All Configurations (Local)",
            "type": "shell",
            "command": "${workspaceFolder}/build-local.sh",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": false,
                "clear": false
            },
            "problemMatcher": {
                "owner": "cpp",
                "fileLocation": [
                    "relative",
                    "${workspaceFolder}/snapclient"
                ],
                "pattern": {
                    "regexp": "^(.*):(\\d+):(\\d+):\\s+(warning|error):\\s+(.*)$",
                    "file": 1,
                    "line": 2,
                    "column": 3,
                    "severity": 4,
                    "message": 5
                }
            }
        },
        {
            "label": "Build Single Configuration (Local)",
            "type": "shell",
            "command": "docker run --rm -v ${workspaceFolder}/snapclient:/project -v ${workspaceFolder}/configs:/project/configs -v ${workspaceFolder}/docs/artifacts:/project/artifacts -w /project espressif/idf:v5.1.1 /bin/bash -c '. /opt/esp/idf/export.sh && cp configs/sdkconfig.${input:configName} sdkconfig && idf.py build'",
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": false,
                "clear": false
            },
            "problemMatcher": {
                "owner": "cpp",
                "fileLocation": [
                    "relative",
                    "${workspaceFolder}/snapclient"
                ],
                "pattern": {
                    "regexp": "^(.*):(\\d+):(\\d+):\\s+(warning|error):\\s+(.*)$",
                    "file": 1,
                    "line": 2,
                    "column": 3,
                    "severity": 4,
                    "message": 5
                }
            }
        },
        {
            "label": "Run Installer (Debug)",
            "type": "shell",
            "command": "npm run dev",
            "options": {
                "cwd": "${workspaceFolder}/installer"
            },
            "isBackground": true,
            "presentation": {
                "echo": true,
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
			"label": "Serve Web Installer (Prod)",
			"type": "shell",
			"command": "python3 -m http.server 8008 -d docs",
			"isBackground": true,
			"problemMatcher": []
		},
    ],
    "inputs": [
        {
            "id": "configName",
            "type": "promptString",
            "description": "Enter config name (e.g., louder-esp-2.0)",
            "default": "louder-esp-2.0"
        }
    ]
}